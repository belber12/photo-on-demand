{
  "manifestVersion": 5,
  "id": "com.starter.ai.panel",
  "name": "AI Starter Panel",
  "version": "0.1.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "23.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "ai-starter-panel",
      "label": {
        "default": "AI Starter Panel"
      },
      "minimumSize": {
        "width": 280,
        "height": 420
      },
      "maximumSize": {
        "width": 900,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 700
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 760
      }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": "all"
    }
  }
}
